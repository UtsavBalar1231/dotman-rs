font_family      FiraCode Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size 16.0

font_features FiraCode Nerd Font +calt +clig +liga +dlig +hlig +onum +cv13 +cv14 +cv17 +cv19 +cv21 +cv24 +cv25 +cv26 +cv28 +cv29 +cv30 +cv31 +cv32 +ss02 +ss06 +ss07 +ss08 +ss09 +ss11 +ss12 +ss13 +ss14 +ss15 +ss16 +ss17 +ss18 +ss19 +ss20

cursor_shape beam
cursor_beam_thickness 2.0
cursor_blink_interval 400

scrollback_lines 30000
wheel_scroll_multiplier 8.0
touch_scroll_multiplier 8.0

# open_url_with firefox-nightly
open_url_with firefox-developer-edition
url_prefixes file ftp ftps gemini git gopher http https irc ircs kitty mailto news sftp ssh
detect_urls yes

#: Performance tuning {{{
repaint_delay 5
input_delay 2
: }}}

#: Terminal bell {{{
enable_audio_bell no
window_alert_on_bell no
#: }}}

#: Window layout {{{

remember_window_size  yes
initial_window_width  640
initial_window_height 400
window_margin_width 4
single_window_margin_width 4
window_padding_width 4
# active_border_color #fbf1c7
# inactive_border_color #fbf1c7
hide_window_decorations no
window_logo_path none
#: }}}

#: Tab bar {{{
tab_bar_margin_width 4.0
tab_bar_margin_height 4.0 4.0
tab_bar_style powerline
tab_switch_strategy previous
tab_title_template         "󰨸 {index} {title}"
active_tab_title_template  "󰅍 {index} {title}"
tab_separator " | "
tab_activity_symbol " ● "

#: Tab bar colors and styles.
# active_tab_foreground   #141414
# active_tab_background   #689d6a
active_tab_font_style   normal-italic
# inactive_tab_foreground #928374
# inactive_tab_background #1d2021
inactive_tab_font_style normal
# tab_bar_background #1d2021
# tab_bar_margin_color #1d2021
#: }}}


background_opacity 1.0

#: Path to a background image. Must be in PNG format.
# background_image ~/Pictures/gruvbox_pixel.png

# dynamic_background_opacity yes

#: Allow changing of the background_opacity dynamically, using either
#: keyboard shortcuts (increase_background_opacity and
#: decrease_background_opacity) or the remote control facility.
#: Changing this option by reloading the config is not supported.

# background_tint 0.0

#: How much to tint the background image by the background color.
#: This option makes it easier to read the text. Tinting is done using
#: the current background color for each window. This option applies
#: only if background_opacity is set and transparent windows are
#: supported or background_image is set.

# dim_opacity 0.75

#: How much to dim text that has the DIM/FAINT attribute set. One
#: means no dimming and zero means fully dimmed (i.e. invisible).
# selection_foreground #000000
# selection_background #fffacd

#: Advanced {{{

# shell .

#: The shell program to execute. The default value of . means to use
#: whatever shell is set as the default shell for the current user.
#: Note that on macOS if you change this, you might need to add
#: --login and --interactive to ensure that the shell starts in
#: interactive mode and reads its startup rc files.

# editor .

#: The terminal based text editor (such as vim or nano) to use when
#: editing the kitty config file or similar tasks.

#: The default value of . means to use the environment variables
#: VISUAL and EDITOR in that order. If these variables aren't set,
#: kitty will run your shell ($SHELL -l -i -c env) to see if your
#: shell startup rc files set VISUAL or EDITOR. If that doesn't work,
#: kitty will cycle through various known editors (vim, emacs, etc.)
#: and take the first one that exists on your system.

# close_on_child_death no

#: Close the window when the child process (shell) exits. With the
#: default value no, the terminal will remain open when the child
#: exits as long as there are still processes outputting to the
#: terminal (for example disowned or backgrounded processes). When
#: enabled with yes, the window will close as soon as the child
#: process exits. Note that setting it to yes means that any
#: background processes still using the terminal can
