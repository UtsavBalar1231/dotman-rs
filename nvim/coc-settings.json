{
	"languageserver": {
		"bash": {
			"command": "bash-language-server",
			"args": ["start"],
			"filetypes": ["sh"]
		},
		"rust-analyzer.enable": true,
		"golang": {
			"command": "gopls",
			"rootPatterns": ["go.mod"],
			"filetypes": ["go"]
		},
		"lua": {
			"command": "lua-lsp",
			"filetypes": ["lua"]
		},
		"python": {
			"command": "pyls",
			"filetypes": ["python"]
		},
		"typescript": {
			"command": "typescript-language-server",
			"filetypes": ["typescript", "typescriptreact"]
		},
		"vim": {
			"command": "vim-language-server",
			"filetypes": ["vim"]
		}
	}
}
