[core]
	pager = bat
	hooksPath = /home/utsav/.git/hooks
	editor = nvim
[interactive]
	diffFilter = diff-so-fancy --patch
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[credential]
	helper = store
[merge]
	log = 10000
	stat = true
	branchdesc = true
	tool = diffmerge
	verbosity = 5
