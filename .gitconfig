[core]
	pager = diff-so-fancy | less --tabs=4 -RFX
	hooksPath = /home/utsav/.git/hooks
[interactive]
	diffFilter = diff-so-fancy --patch
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[user]
	name = UtsavBalar1231
	email = utsavbalar1231@gmail.com
[credential]
	helper = store
[merge]
	log = 10000
	stat = true
	branchdesc = true
	tool = diffmerge
	verbosity = 5
